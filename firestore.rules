rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /surveyResponses/{documentId} {
      allow read: if false;
      allow update, delete: if false;
      allow create: if
        request.resource.data.keys().hasOnly([
          'createdAt',
          'demographics',
          'spotify',
          'exposure',
          'hearing',
          'notes',
          'computed'
        ]) &&
        request.resource.data.createdAt is string &&
        request.resource.data.demographics.ageRange is string &&
        request.resource.data.demographics.region is string &&
        request.resource.data.demographics.gender is string &&
        request.resource.data.spotify.connected is bool &&
        request.resource.data.spotify.topGenres is list &&
        request.resource.data.spotify.topArtists is list &&
        request.resource.data.spotify.spotifyPlan is string &&
        (
          request.resource.data.spotify.importedAt == null ||
          request.resource.data.spotify.importedAt is string
        ) &&
        request.resource.data.spotify.selfReportedListeningHoursPerWeek is number &&
        request.resource.data.spotify.listeningHoursSource is string &&
        (
          request.resource.data.spotify.importedHistoryFileCount == null ||
          request.resource.data.spotify.importedHistoryFileCount is number
        ) &&
        (
          request.resource.data.spotify.importedHistoryRecordCount == null ||
          request.resource.data.spotify.importedHistoryRecordCount is number
        ) &&
        (
          request.resource.data.spotify.importedHoursTotal == null ||
          request.resource.data.spotify.importedHoursTotal is number
        ) &&
        (
          request.resource.data.spotify.importedAverageHoursPerWeek == null ||
          request.resource.data.spotify.importedAverageHoursPerWeek is number
        ) &&
        (
          request.resource.data.spotify.importedHistorySpanDays == null ||
          request.resource.data.spotify.importedHistorySpanDays is number
        ) &&
        request.resource.data.exposure.workNoiseHoursPerWeek is number &&
        request.resource.data.exposure.commuteNoiseHoursPerWeek is number &&
        request.resource.data.exposure.leisureNoiseHoursPerWeek is number &&
        request.resource.data.exposure.averageHeadphoneVolume is number &&
        request.resource.data.exposure.weeklyHighVolumeSessions is number &&
        request.resource.data.exposure.hearingProtectionUsage is number &&
        request.resource.data.exposure.recentRingingEpisodes is number &&
        request.resource.data.exposure.perceivedRecoveryHours is number &&
        request.resource.data.hearing.qualityToday is number &&
        request.resource.data.hearing.speechInNoiseDifficulty is number &&
        request.resource.data.hearing.leftEarDifference is number &&
        request.resource.data.hearing.tinnitusSeverity is number &&
        request.resource.data.hearing.soundSensitivity is number &&
        (
          request.resource.data.hearing.maxFrequencyCheck.highestHeardHz == null ||
          request.resource.data.hearing.maxFrequencyCheck.highestHeardHz is number
        ) &&
        request.resource.data.hearing.maxFrequencyCheck.headphoneType is string &&
        request.resource.data.hearing.maxFrequencyCheck.environmentNoise is number &&
        request.resource.data.notes is string &&
        request.resource.data.computed.estimatedWeeklyNoiseDose is number &&
        request.resource.data.computed.hearingStrainIndex is number;
    }
  }
}
